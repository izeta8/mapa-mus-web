{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx eslint *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Bash(git checkout *)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{ "type": "command", "command": "node ../.agent/scripts/check-schema-change.cjs --self mapa-mus-web" }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "node ../.agent/scripts/check-schema-change.cjs --self mapa-mus-web" }]
      },
      {
        "matcher": "mcp__supabase__apply_migration",
        "hooks": [{ "type": "command", "command": "node ../.agent/scripts/check-schema-change.cjs --self mapa-mus-web" }]
      }
    ]
  }
}
